# =============================================================================
# PolyTraderX Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=PolyTraderX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (MySQL 8 required) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=polytraderx
DB_USERNAME=root
DB_PASSWORD=

# --- Session ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Queue / Cache / Filesystem ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

# --- Mail (for password resets, email verification) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"

# --- Google OAuth (for "Sign in with Google") ---
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# --- NOWPayments (crypto subscription billing) ---
# Get API key at https://nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# --- Superadmin Account (created during db:seed) ---
SUPERADMIN_EMAIL=admin@polytraderx.com
SUPERADMIN_PASSWORD=password

# =============================================================================
# NOTE: The following API keys are stored in the `platform_settings` database
# table (managed via Admin > Settings), NOT in .env:
#
#   - TELEGRAM_BOT_TOKEN      (Telegram Bot API token)
#   - ANTHROPIC_API_KEY        (Claude API key for Muscles + Brain tiers)
#
# Per-user API keys (Polymarket credentials) are stored encrypted in the
# `user_credentials` table, managed via Settings > Credentials.
# =============================================================================
